{
  "name": "ynab-control-panel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "ynab-control-panel": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
